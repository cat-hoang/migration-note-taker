# Copy this to .env.local and fill in your keys.
# Only the keys for the providers you want to use are required.
# "Quick Scan (No AI)" mode works without any keys.

# Required for Claude (Anthropic) mode
ANTHROPIC_API_KEY=

# Required for OpenAI / Copilot mode
OPENAI_API_KEY=

# Optional: override the base URL for Azure OpenAI or GitHub Copilot
# Leave blank to use the default OpenAI endpoint
OPENAI_BASE_URL=

# Optional: change the OpenAI model (default: gpt-4o)
OPENAI_MODEL=gpt-4o
